{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.opennotes.in/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://api.opennotes.in/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*.)",
      "destination": "/index.html"
    }
  ]
}
